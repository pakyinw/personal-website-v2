{
    "extends": "airbnb",
    "rules": {
      "react/jsx-filename-extension": [1, { "extensions": [".js", ".jsx"] }]
    },
    "settings" : {
      "import/resolver": {
          "node": {
              "extensions": [".js", ".jsx", ".ts", ".tsx"],
              "moduleDirectory": ["node_modules", "src/"]
          }
      }
    },
    "ignorePatterns": ["node_modules/**","src/__snapshots__/**", "**/*.test.js","src/reportWebVitals.js","src/index.js"]
}